<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="8dp"
    android:background="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/bookmark_favicon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_globe_24"
        android:scaleType="fitCenter" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="4dp">

        <TextView
            android:id="@+id/bookmark_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/bookmark_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_medium"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/bookmark_delete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_close_24"
        android:padding="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/on_surface_medium"
        android:contentDescription="Delete bookmark" />

</LinearLayout>
