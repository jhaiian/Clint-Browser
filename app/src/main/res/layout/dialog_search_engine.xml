<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="16dp">

    <RadioGroup
        android:id="@+id/radioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radioDuckDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/engine_duckduckgo"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:buttonTint="@color/purple_300"
            android:background="?attr/selectableItemBackground" />

        <RadioButton
            android:id="@+id/radioBraveDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/engine_brave"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:buttonTint="@color/purple_300"
            android:background="?attr/selectableItemBackground" />

        <RadioButton
            android:id="@+id/radioGoogleDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/engine_google"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:buttonTint="@color/purple_300"
            android:background="?attr/selectableItemBackground" />

    </RadioGroup>

</LinearLayout>
